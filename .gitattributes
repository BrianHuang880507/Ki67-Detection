# Normalize text files through Git, then keep project source files on LF
# so Windows checkouts do not rewrite Python files to CRLF.
* text=auto
.gitattributes text eol=lf

*.py text eol=lf
*.pyw text eol=lf
*.ipynb text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
